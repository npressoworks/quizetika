# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# サーバーサイド専用の機密キー（NEXT_PUBLIC_を付けないこと）
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=YOUR_ADSENSE_CLIENT_ID

# 広告の一時的な非表示切り替え (true で非表示、false または未指定で表示)
NEXT_PUBLIC_DISABLE_ADS=false

# BigQuery Export (Edge Function: bigquery-export)
# 実デプロイでは Next.js の環境変数ではなく `supabase secrets set` で設定する。
# ここはローカル開発時の参考用プレースホルダ。
GCP_SERVICE_ACCOUNT_JSON=YOUR_GCP_SERVICE_ACCOUNT_JSON
BQ_PROJECT_ID=YOUR_BQ_PROJECT_ID
BQ_DATASET_ID=YOUR_BQ_DATASET_ID
ANALYTICS_WEBHOOK_SECRET=YOUR_ANALYTICS_WEBHOOK_SECRET

